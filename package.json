{
  "name": "wildlight",
  "version": "0.1.0",
  "private": true,
  "description": "Wildlight Imagery — artist storefront for Dan Raby",
  "scripts": {
    "dev": "next dev",
    "build": "tsx lib/migrate.ts && next build",
    "build:skip-migrate": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "scrape": "node scripts/scrape-wildlight.js",
    "import:manifest": "tsx scripts/import-manifest.ts",
    "curate:build": "node scripts/build-curate.js",
    "publish:selections": "tsx scripts/publish-selections.ts",
    "seed:admins": "tsx scripts/seed-admins.ts",
    "sync:printful": "tsx scripts/sync-printful-products.ts",
    "backfill:image-dims": "tsx scripts/backfill-image-dims.ts",
    "demote:orphans": "tsx scripts/demote-orphan-publishes.ts",
    "cleanup:staged": "tsx scripts/cleanup-staged.ts",
    "migrate": "tsx lib/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@aws-sdk/client-s3": "^3.674.0",
    "@aws-sdk/s3-request-presigner": "^3.674.0",
    "@sentry/nextjs": "^10.50.0",
    "@stripe/stripe-js": "^9.3.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "exifr": "^7.1.3",
    "file-type": "^22.0.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.2.4",
    "pg": "^8.13.1",
    "probe-image-size": "^7.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^4.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/probe-image-size": "^7.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^2.1.5",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vercel": "^52.0.0",
    "vitest": "^2.1.5"
  }
